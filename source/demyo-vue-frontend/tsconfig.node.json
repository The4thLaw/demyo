  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,

	"paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["auto-imports.d.ts", "types/java-models.d.ts", "vite.config.ts", "vitest.config.ts", "vite-plugins/**/*.ts", "tests/**/*.ts"]
}
